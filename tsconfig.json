{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2022",
      "WebWorker"
    ],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "types": [
      "@cloudflare/workers-types"
    ],
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
